      '<p class="sc-order-confirm__total">鍚堣閲戦 <strong>' +
      fmtMoney(pending.total) +
      '</strong></p></div>'
    );
  }

  function renderOrderSuccessCard(order, customerName, total) {
    const lineHtml = (order.lines || [])
      .map(function (line) {
        const unit = line.salesUnit || '浠?;
        return (
          '<p class="sc-card__meta sc-order-success-line"><strong>' +
          App.escapeHtml(line.inventoryName || '鈥?) +
          '</strong> 路 ' +
          App.escapeHtml(formatOrderLineSpec(line)) +
          ' 路 ' +
          line.qty +
          ' ' +
          App.escapeHtml(unit) +
          '</p>'
        );
      })
      .join('');
    return (
      '<div class="sc-card" data-spec-id="card-order-success"><div class="sc-card__head sc-card__head--compact">璁㈠崟鎻愪氦鎴愬姛</div><div class="sc-card__row sc-card__row--compact">' +
      '<p class="sc-card__meta">璁㈠崟鍙凤細<strong>' +
      App.escapeHtml(order.no) +
      '</strong></p><p class="sc-card__meta">瀹㈡埛锛? +
      App.escapeHtml(customerName) +
      '</p><p class="sc-card__meta">鐘舵€侊細' +
      App.escapeHtml(order.status) +
