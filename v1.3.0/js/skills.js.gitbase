    ctx().changeOrderId = oid;
    App.pushAiHtml(renderChangeFormCard(oid));
    rescanAnnotationPins();
  }

  function renderChangeFormCard(oid) {
    const o = DemoData.orders.find(function (x) {
      return x.id === oid;
    });
    const reasons = (DemoData.changeReasons || [])
      .map(function (r) {
        return '<option value="' + App.escapeHtml(r) + '">' + App.escapeHtml(r) + '</option>';
      })
      .join('');
    return (
      '<div class="sc-card sc-card--compact sc-card--inline-form" data-spec-id="sheet-change" data-spec-pin-root data-change-oid="' +
      App.escapeHtml(oid) +
      '">' +
      '<div class="sc-card__head sc-card__head--compact">鍙樻洿璁㈠崟 鈥?' +
      App.escapeHtml(o ? o.no : '') +
      '</div>' +
      '<label class="sc-field-label">鍙樻洿鍘熷洜</label>' +
      '<select class="sc-input sc-input--field" data-field="change-reason">' +
      reasons +
      '</select>' +
      '<label class="sc-field-label">澶囨敞</label>' +
      '<textarea class="sc-textarea" data-field="change-remark" placeholder="璇疯鏄庡彉鏇村唴瀹光€?></textarea>' +
      '<div class="sc-card__actions-inline"><button type="button" class="sc-btn sc-btn--primary" data-action="change-submit">鎻愪氦鍙樻洿</button></div>' +
      '</div>'
    );
  }

  function submitChange() {
    const card = getActiveFormCard('sheet-change');
    const oid = (card && card.getAttribute('data-change-oid')) || ctx().changeOrderId;
    const o = DemoData.orders.find(function (x) {
      return x.id === oid;
    });
    const reasonEl = card && card.querySelector('[data-field="change-reason"]');
    const remarkEl = card && card.querySelector('[data-field="change-remark"]');
    const reason = reasonEl ? reasonEl.value : '';
    const remark = remarkEl ? remarkEl.value.trim() : '';
    if (!remark) {
      App.toast('璇峰～鍐欏彉鏇村娉?);
      return;
    }
    if (o && o.status === '宸插鏍?) {
      o.status = '閿€鍞鏍?;
      o.statusDetail = '鍙樻洿鐢宠宸插彈鐞嗭紝閲嶆柊杩涘叆閿€鍞鏍?;
    } else if (o) {
      o.statusDetail = (o.statusDetail || '') + '锛涘彉鏇寸敵璇峰凡鍙楃悊';
    }
    App.closeOverlays();
    App.pushAiHtml(
      '<div class="sc-card" data-spec-id="card-change-success"><div class="sc-card__head sc-card__head--compact">鍙樻洿宸叉彁浜?/div>' +
      '<div class="sc-card__row sc-card__row--compact"><p class="sc-card__meta">璁㈠崟 <strong>' +
      App.escapeHtml(o ? o.no : '') +
      '</strong></p><p class="sc-card__meta">鍘熷洜锛? +
      App.escapeHtml(reason) +
      '锛涘娉細' +
      App.escapeHtml(remark) +
      '</p></div></div>'
    );
    rescanAnnotationPins();
  }

