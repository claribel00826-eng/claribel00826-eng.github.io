    },
    orderSource: {
      message: '璇烽€夋嫨涓嬪崟鏉ユ簮锛氭寜鎶ヤ环鍗曟垨鐩存帴閫夊搧',
      specId: 'card-order-source',
      ensureCard: function () {
        enterSkill('order');
        const c = activeCustomer();
        if (!c) return;
        if (document.querySelector('[data-spec-id="card-quote-pick"]')) return;
        if (document.querySelector('[data-spec-id="card-order-source"]')) return;
        beginOrderCreate();
      }
    },
    orderNoQuotes: {
      message: '鏆傛棤鏈鎴锋姤浠峰崟锛岃浠庨€夊搧鎶ヤ环鍗￠€夊搧鍚庨€愰」鎶ヤ环',
      hint: '鍙銆岄€夊搧 鍏抽敭璇嶃€嶆垨鍕鹃€変骇鍝?,
      toast: '鏆傛棤鎶ヤ环鍗曪紝宸茶繘鍏ラ€夊搧鎶ヤ环',
      specId: 'card-quote-pick',
      ensureCard: function () {
        const c = activeCustomer();
        if (!c) return;
        enterSkill('order');
        if (!document.querySelector('[data-spec-id="card-quote-pick"]')) {
          orderDirectStart();
        }
      }
    },
    orderQuotePick: {
      message: '璇烽€夋嫨瑕佷笅鍗曠殑鎶ヤ环鍗?,
      hint: '鐐归€変笅鍒椾竴琛岋紝鎴栬鍑烘姤浠峰崟缂栧彿/妯℃澘鍚?,
      specId: 'card-quote-select',
