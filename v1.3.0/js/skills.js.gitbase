    },
    quoteNoScheme: {
      message: '鏆傛棤鏈鎴锋柟妗堬紝璇蜂粠閫夊搧鎶ヤ环鍗￠€夊搧鍚庨€愰」鎶ヤ环',
      hint: '鍙銆岄€夊搧 鍏抽敭璇嶃€嶆垨鍕鹃€変骇鍝?,
      specId: 'card-quote-pick',
      ensureCard: function () {
