  function utteranceFor(id) {
    return (DemoData.skillUtterances && DemoData.skillUtterances[id]) || id;
  }

  function enterSkill(skillId) {
    if (App.switchActiveSkill) App.switchActiveSkill(skillId, { skipSkillAnnounce: true });
  }

  function requireCustomer(pendingSkillId) {
    const c = activeCustomer();
    if (c) return c;
    guideMissingSlot('customer', { skillId: pendingSkillId || App.state.activeSkill });
    return null;
  }

  function activeCustomer() {
    return App.getCustomer(App.state.selectedFollowUpId || App.state.customerId);
  }

  function ensureSchemesStore() {
    if (!Array.isArray(ctx().schemes)) {
      ctx().schemes = [];
      if (ctx().scheme && ctx().scheme.id) ctx().schemes.push(ctx().scheme);
    }
  }

  function schemesForCustomer(cid) {
    ensureSchemesStore();
    return ctx().schemes.filter((s) => s.customerId === cid);
  }

  function persistScheme(scheme) {
    ensureSchemesStore();
    const idx = ctx().schemes.findIndex((s) => s.id === scheme.id);
    if (idx >= 0) ctx().schemes[idx] = scheme;
    else ctx().schemes.push(scheme);
    ctx().scheme = scheme;
    ctx().activeSchemeId = scheme.id;
    App.saveState();
    return scheme;
  }

  function schemePickSummary(s) {
    const lines = s.lines || [];
    if (!lines.length) return '鏃犳槑缁?;
    const preview = lines
      .slice(0, 2)
      .map((l) => (l.name || '鍝侀」') + '脳' + (l.qty || 1))
      .join('銆?);
    return lines.length > 2 ? preview + ' 绛? + lines.length + '椤? : preview;
  }

  function setActivePickList(type, list, mode) {
    const display = (list || []).slice().reverse();
    ctx().activePickList = {
      type: type,
      mode: mode || (type === 'quote' ? 'order' : 'quote'),
      ids: display.map(function (item) {
        return item.id;
      })
    };
  }

  function clearActivePickList() {
    delete ctx().activePickList;
  }

  function parsePickListIndex(text) {
    const t = (text || '').trim().replace(/\s+/g, '');
    if (!t) return null;
    const digitMap = { 涓€: 1, 浜? 2, 涓? 3, 鍥? 4, 浜? 5, 鍏? 6, 涓? 7, 鍏? 8, 涔? 9 };
    function parseToken(tok) {
      if (/^\d+$/.test(tok)) return parseInt(tok, 10);
      if (tok === '鍗?) return 10;
      if (tok.length === 2 && tok[0] === '鍗? && digitMap[tok[1]]) return 10 + digitMap[tok[1]];
      if (tok.length === 2 && tok[1] === '鍗? && digitMap[tok[0]]) return digitMap[tok[0]] * 10;
      return digitMap[tok] || null;
    }
    let m =
      t.match(/^绗?([涓€浜屼笁鍥涗簲鍏竷鍏節鍗乗d]{1,3})[涓」鏉¤]?$/) ||
      t.match(/^閫??:绗??([涓€浜屼笁鍥涗簲鍏竷鍏節鍗乗d]{1,3})[涓」鏉¤]?$/) ||
      t.match(/^([1-9]\d*)$/);
    if (!m) return null;
    const n = parseToken(m[1]);
    return n >= 1 ? n : null;
  }

  function latestPickListCardSpecId(type) {
    if (type === 'scheme') return 'card-scheme-pick';
    if (type === 'order') return 'card-order-select';
    return 'card-quote-select';
  }

  function applySchemePickById(sid, opts) {
    opts = opts || {};
    const demand = ctx().pendingSchemeQuoteDemand;
    delete ctx().pendingSchemeQuoteDemand;
    const scheme = schemeForActiveCustomer(sid);
    if (!scheme) {
      App.toast('鏈壘鍒版墍閫夋柟妗?);
      return false;
    }
    if (opts.simulateUserMsg) {
      simulateUserUtterance(
        '閫夋嫨鏂规 ' + (scheme.templateName || scheme.id)
      );
    }
    clearActivePickList();
    persistScheme(scheme);
    if (demand) {
      enterSkill('quote');
      publishQuoteFromSchemeDemand(scheme, demand);
    } else {
      quoteFromScheme(sid);
    }
    return true;
  }

  function applyQuotePickById(qid, opts) {
    opts = opts || {};
    const quote = quoteForActiveCustomer(qid);
    if (!quote) {
      App.toast('鏈壘鍒版墍閫夋姤浠峰崟');
      return false;
    }
    if (opts.simulateUserMsg) {
      simulateUserUtterance('鎸夋姤浠峰崟 ' + quote.id + ' 涓嬪崟');
    }
    clearActivePickList();
    const rowNote = ctx()._lastPickRowIndex ? '锛堢 ' + ctx()._lastPickRowIndex + ' 鏉★級' : '';
    delete ctx()._lastPickRowIndex;
    enterSkill('order');
    App.pushAiHtml(
      '<p class="sc-reply-lead">宸叉寜鎶ヤ环鍗?<strong>' +
        App.escapeHtml(quote.id) +
        '</strong>' +
        rowNote +
        ' 鎵撳紑涓嬪崟纭銆?/p>'
    );
    applyOrderFromQuote(quote);
    return true;
  }

  /** 閫夋嫨鏂规/鎶ヤ环鍗曞崱灞曠ず鏃讹細璇煶銆岀 N 鏉°€嶆垨鍚嶇О/缂栧彿鐐归€?*/
  function tryActivePickListUtterance(text) {
    const pick = ctx().activePickList;
    if (!pick || !pick.ids || !pick.ids.length) return false;
    const specId = latestPickListCardSpecId(pick.type);
    if (!document.querySelector('[data-spec-id="' + specId + '"]')) return false;

    const t = (text || '').trim();
    const rowIdx = parsePickListIndex(t);
    if (rowIdx != null) {
      const id = pick.ids[rowIdx - 1];
      if (!id) {
        App.toast('娌℃湁绗?' + rowIdx + ' 鏉★紝褰撳墠鍏?' + pick.ids.length + ' 鏉″彲閫?);
        return true;
      }
      ctx()._lastPickRowIndex = rowIdx;
      if (pick.mode === 'view') {
        if (pick.type === 'scheme') {
          return viewSchemeById(id, { announceRow: rowIdx });
        }
        if (pick.type === 'order') {
          return viewOrderById(id, { announceRow: rowIdx });
        }
        return viewQuoteById(id, { announceRow: rowIdx });
      }
      if (pick.type === 'scheme') {
        App.pushAiHtml(
          '<p class="sc-card__meta">宸查€夌 <strong>' +
            rowIdx +
            '</strong> 鏉℃柟妗堬紝杩涘叆閫愰」鎶ヤ环銆?/p>'
        );
        return applySchemePickById(id);
      }
      return applyQuotePickById(id);
    }

    const k = t.toLowerCase();
    if (k.length >= 2) {
    const c = activeCustomer();
      if (c && pick.type === 'scheme') {
        const hit = pick.ids
          .map(function (id) {
            return schemesForCustomer(c.id).find(function (s) {
              return s.id === id;
            });
          })
          .filter(Boolean)
          .find(function (s) {
            return (
              (s.templateName || '').toLowerCase().indexOf(k) >= 0 ||
              s.id.toLowerCase().indexOf(k) >= 0
            );
          });
        if (hit) {
          if (pick.mode === 'view') return viewSchemeById(hit.id);
          App.pushAiHtml(
            '<p class="sc-card__meta">宸查€夋柟妗堛€? + App.escapeHtml(hit.templateName || hit.id) + '銆嶃€?/p>'
          );
          return applySchemePickById(hit.id);
        }
      }
      if (c && pick.type === 'quote') {
        const hit = pick.ids
          .map(function (id) {
            return quotesForCustomer(c.id).find(function (q) {
              return q.id === id;
            });
          })
          .filter(Boolean)
          .find(function (q) {
            return (
              q.id.toLowerCase().indexOf(k) >= 0 ||
              (q.templateName || '').toLowerCase().indexOf(k) >= 0
            );
          });
        if (hit) {
          if (pick.mode === 'view') return viewQuoteById(hit.id);
          App.pushAiHtml(
            '<p class="sc-card__meta">宸查€夋姤浠峰崟銆? + App.escapeHtml(hit.id) + '銆嶃€?/p>'
          );
          return applyQuotePickById(hit.id);
        }
      }
      if (c && pick.type === 'order') {
        const hit = pick.ids
          .map(function (id) {
            return ordersForCustomer(c.id).find(function (o) {
              return o.id === id;
            });
          })
          .filter(Boolean)
          .find(function (o) {
            return (
              (o.no || '').toLowerCase().indexOf(k) >= 0 ||
              (o.status || '').toLowerCase().indexOf(k) >= 0
            );
          });
        if (hit) {
          return viewOrderById(hit.id);
        }
      }
    }
    return false;
  }

  function isViewSchemeHistoryPhrase(t) {
    const text = (t || '').trim();
    if (!text) return false;
    if (/閰嶄釜鏂规|鍋氭柟妗坾鏂规閫熼厤|鎸夋柟妗圽s*鎶ヤ环|鍘绘姤浠穦鐢熸垚鏂规|淇濆瓨鏂规|鍒涘缓鏂版柟妗坾鏂板缓鏂规/.test(text))
      return false;
    if (/(?:鏌ョ湅|鐪嬬湅|鍒楀嚭|鏈夊摢浜泑鍘嗗彶|鎵撳紑|棰勮|鏄剧ず).*(?:鍘嗗彶鏁版嵁|鏂规)/.test(text)) return true;
    if (/鏌ョ湅鍘嗗彶鏁版嵁|鍘嗗彶鏁版嵁/.test(text)) return true;
    if (/(?:鏂规).*(?:鍒楄〃|璁板綍|鍘嗗彶|pdf|PDF)/i.test(text)) return true;
    if (/^棰勮\s*鏂规/.test(text)) return true;
    return false;
  }

  function isPlanSkillAtEntry() {
    return !!ctx().planSkillAtEntry;
  }

  function setPlanSkillAtEntry(on) {
    if (on) ctx().planSkillAtEntry = true;
    else if (ctx().planSkillAtEntry) delete ctx().planSkillAtEntry;
  }

  function isPlanCreateEntryPhrase(t) {
    const text = (t || '').trim();
    if (!text) return false;
    if (isViewSchemeHistoryPhrase(text)) return false;
    if (/鍒涘缓鏂版柟妗坾鏂板缓鏂规|鏂版柟妗坾閲嶆柊閰嶆柟妗坾寮€濮嬪仛鏂规|寮€濮嬮厤鏂规/.test(text)) return true;
    if (/閰嶄釜鏂规|鍋氭柟妗坾鏂规閫熼厤/.test(text)) return true;
    return false;
  }

  function isPlanViewHistoryEntryPhrase(t) {
    return isViewSchemeHistoryPhrase(t);
  }

  function planEntryCustomerBadge(c) {
    if (!c || !DemoData.isNewCustomer) return '';
    if (DemoData.isNewCustomer(c)) {
      return '<span class="sc-badge sc-badge--new">鏂板鎴?/span>';
    }
    if (DemoData.isOldCustomer && DemoData.isOldCustomer(c, DemoData.salesperson)) {
      return '<span class="sc-badge sc-badge--a">鑰佸鎴?/span>';
    }
    return '';
  }

  function renderPlanSkillEntryCard(c) {
    seedDemoHistoryIfEmpty(c);
    const count = schemesForCustomer(c.id).length;
    const historySub =
      count > 0 ? '鍏?' + count + ' 涓凡淇濆瓨鏂规' : '鏆傛棤宸蹭繚瀛樻柟妗?;
    const historyRow =
      count > 0
        ? '<button type="button" class="sc-plan-entry__option" data-action="plan-view-history">' +
          '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鏌ョ湅鍘嗗彶鏂规</span>' +
          '<span class="sc-plan-entry__option-desc">' +
          App.escapeHtml(historySub) +
          '</span></span>' +
          '<span class="sc-plan-entry__chevron" aria-hidden="true">鈥?/span></button>'
        : '<div class="sc-plan-entry__option sc-plan-entry__option--disabled" aria-disabled="true">' +
          '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鏌ョ湅鍘嗗彶鏂规</span>' +
          '<span class="sc-plan-entry__option-desc">' +
          App.escapeHtml(historySub) +
          '</span></span></div>';
    return (
      '<div class="sc-card sc-card--plan-entry" data-spec-id="card-plan-entry">' +
      '<div class="sc-plan-entry__head">' +
      '<p class="sc-plan-entry__kicker">鏂规閫熼厤</p>' +
      '<div class="sc-plan-entry__customer-row">' +
      '<span class="sc-plan-entry__customer">' +
      App.escapeHtml(c.name) +
      '</span>' +
      planEntryCustomerBadge(c) +
      '</div></div>' +
      '<div class="sc-plan-entry__actions" role="group" aria-label="鏂规閫熼厤鎿嶄綔">' +
      historyRow +
      '<button type="button" class="sc-plan-entry__option sc-plan-entry__option--primary" data-action="plan-create-new">' +
      '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鍒涘缓鏂版柟妗?/span>' +
      '<span class="sc-plan-entry__option-desc">閫夊搧銆侀瑙堝苟淇濆瓨鏂规</span></span>' +
      '<span class="sc-plan-entry__chevron" aria-hidden="true">鈥?/span></button>' +
      '</div></div>'
    );
  }

  function showPlanSkillEntry(opts) {
    opts = opts || {};
    const c = ensurePlan(opts.customer) || activeCustomer();
    if (!c) {
      requireCustomer('plan');
      return;
    }
    ensurePlan(c);
    setPlanSkillAtEntry(true);
    enterSkill('plan');
    const html =
      opts.leadHtml != null && !opts.onlyCard
        ? opts.leadHtml + renderPlanSkillEntryCard(c)
        : renderPlanSkillEntryCard(c);
    App.pushAiHtml(html);
    rescanAnnotationPins();
  }

  function openPlanHistoryFromEntry(opts) {
    opts = opts || {};
    setPlanSkillAtEntry(false);
    const c = activeCustomer() || requireCustomer('plan');
    if (!c) return;
    enterSkill('plan');
    seedDemoHistoryIfEmpty(c);
    const pool = schemesForCustomer(c.id);
    if (!pool.length) {
      App.pushAiHtml(renderPlanSkillEntryCard(c));
      setPlanSkillAtEntry(true);
      rescanAnnotationPins();
      return;
    }
    pushSchemeHistoryView(
      c,
      pool,
      opts.leadHtml || '<p class="sc-reply-lead">鏌ョ湅鍘嗗彶鏂规锛?/p>'
    );
    rescanAnnotationPins();
  }

  function resetPlanDraftForCreate(c) {
    ctx().plan = {
      customerId: c.id,
      filter: '',
      demandText: '',
      awaitingDemand: false,
      selected: {},
      sku: {},
      qty: {},
      templateId: null,
      moreVisible: PLAN_MORE_PAGE_SIZE
    };
  }

  function tryPlanEntryIntent(t) {
    if (!isPlanSkillAtEntry()) return false;
    const text = (t || '').trim();
    if (!text) return true;
    if (isPlanViewHistoryEntryPhrase(text)) {
      openPlanHistoryFromEntry();
      return true;
    }
    if (isPlanCreateEntryPhrase(text)) {
      beginPlanCreate();
      return true;
    }
    if (/^閫夊搧|^棰勮|^鐢熸垚鏂规|^淇濆瓨鏂规|^绛涢€墊^杩囨护/.test(text)) {
      guideMissingSlot('planEntryChoice');
      return true;
    }
    guideMissingSlot('planEntryChoice');
    return true;
  }

  function isQuoteSkillAtEntry() {
    return !!ctx().quoteSkillAtEntry;
  }

  function setQuoteSkillAtEntry(on) {
    if (on) ctx().quoteSkillAtEntry = true;
    else if (ctx().quoteSkillAtEntry) delete ctx().quoteSkillAtEntry;
  }

  function isQuoteCreateEntryPhrase(t) {
    const text = (t || '').trim();
    if (!text) return false;
    if (isViewQuoteHistoryPhrase(text)) return false;
    if (isSchemeQuoteEntryPhrase(text)) return false;
    if (/鍒涘缓鏂版姤浠穦鏂板缓鎶ヤ环|鏂版姤浠穦寮€濮嬫姤浠?.test(text)) return true;
    return isQuoteEntryPhrase(text);
  }

  function isQuoteViewHistoryEntryPhrase(t) {
    const text = (t || '').trim();
    if (isViewQuoteHistoryPhrase(text)) return true;
    if (isQuoteSkillAtEntry() && /鏌ョ湅鍘嗗彶鏁版嵁/.test(text)) return true;
    return false;
  }

  function renderQuoteSkillEntryCard(c) {
    seedDemoHistoryIfEmpty(c);
    const count = quotesForCustomer(c.id).length;
    const historySub =
      count > 0 ? '鍏?' + count + ' 浠藉巻鍙叉姤浠峰崟' : '鏆傛棤鍘嗗彶鎶ヤ环鍗?;
    const historyRow =
      count > 0
        ? '<button type="button" class="sc-plan-entry__option" data-action="quote-view-history">' +
          '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鏌ョ湅鍘嗗彶鎶ヤ环鍗?/span>' +
          '<span class="sc-plan-entry__option-desc">' +
          App.escapeHtml(historySub) +
          '</span></span>' +
          '<span class="sc-plan-entry__chevron" aria-hidden="true">鈥?/span></button>'
        : '<div class="sc-plan-entry__option sc-plan-entry__option--disabled" aria-disabled="true">' +
          '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鏌ョ湅鍘嗗彶鎶ヤ环鍗?/span>' +
          '<span class="sc-plan-entry__option-desc">' +
          App.escapeHtml(historySub) +
          '</span></span></div>';
    return (
      '<div class="sc-card sc-card--plan-entry" data-spec-id="card-quote-entry">' +
      '<div class="sc-plan-entry__head">' +
      '<p class="sc-plan-entry__kicker">浜у搧鎶ヤ环</p>' +
      '<div class="sc-plan-entry__customer-row">' +
      '<span class="sc-plan-entry__customer">' +
      App.escapeHtml(c.name) +
      '</span>' +
      planEntryCustomerBadge(c) +
      '</div></div>' +
      '<div class="sc-plan-entry__actions" role="group" aria-label="浜у搧鎶ヤ环鎿嶄綔">' +
      historyRow +
      '<button type="button" class="sc-plan-entry__option sc-plan-entry__option--primary" data-action="quote-create-new">' +
      '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鏂板缓鎶ヤ环</span>' +
      '<span class="sc-plan-entry__option-desc">鎸夋柟妗堟垨鐩撮€夊搧锛岄€愰」濉环鍑烘姤浠峰崟</span></span>' +
      '<span class="sc-plan-entry__chevron" aria-hidden="true">鈥?/span></button>' +
      '</div></div>'
    );
  }

  function showQuoteSkillEntry(opts) {
    opts = opts || {};
    const c = activeCustomer() || requireCustomer('quote');
    if (!c) return;
    setQuoteSkillAtEntry(true);
    enterSkill('quote');
    const html =
      opts.leadHtml != null && !opts.onlyCard
        ? opts.leadHtml + renderQuoteSkillEntryCard(c)
        : renderQuoteSkillEntryCard(c);
    App.pushAiHtml(html);
    rescanAnnotationPins();
  }

  function openQuoteHistoryFromEntry(opts) {
    opts = opts || {};
    setQuoteSkillAtEntry(false);
    const c = activeCustomer() || requireCustomer('quote');
    if (!c) return;
    enterSkill('quote');
    seedDemoHistoryIfEmpty(c);
    const pool = quotesForCustomer(c.id);
    if (!pool.length) {
      App.pushAiHtml(renderQuoteSkillEntryCard(c));
      setQuoteSkillAtEntry(true);
      rescanAnnotationPins();
      return;
    }
    pushQuoteHistoryView(
      c,
      pool,
      opts.leadHtml ||
        '<p class="sc-reply-lead">涓?<strong>' +
          App.escapeHtml(c.name) +
          '</strong> 鏌ョ湅鍘嗗彶鎶ヤ环鍗曪細</p>'
    );
    rescanAnnotationPins();
  }

  function tryQuoteEntryIntent(t) {
    if (!isQuoteSkillAtEntry()) return false;
    const text = (t || '').trim();
    if (!text) return true;
    if (isQuoteViewHistoryEntryPhrase(text)) {
      openQuoteHistoryFromEntry();
      return true;
    }
    if (isQuoteCreateEntryPhrase(text)) {
      beginQuoteCreate();
      return true;
    }
    if (/^閫夊搧|^鎸夋柟妗坾^鐩存帴閫夊搧|^閫愰」|^鐢熸垚鎶ヤ环鍗晐^绛涢€墊^杩囨护/.test(text)) {
      guideMissingSlot('quoteEntryChoice');
      return true;
    }
    guideMissingSlot('quoteEntryChoice');
    return true;
  }

  function isOrderSkillAtEntry() {
    return !!ctx().orderSkillAtEntry;
  }

  function setOrderSkillAtEntry(on) {
    if (on) ctx().orderSkillAtEntry = true;
    else if (ctx().orderSkillAtEntry) delete ctx().orderSkillAtEntry;
  }

  function isViewOrderHistoryPhrase(t) {
    const text = (t || '').trim();
    if (!text) return false;
    if (/纭涓嬪崟|鎸夋姤浠峰崟|鐩存帴閫夊搧|鐢熸垚璁㈠崟|缁?+涓嬪崟|澶嶅埗璁㈠崟|鍙樻洿.*璁㈠崟/.test(text)) return false;
    if (/杩涘害|璁㈠崟鍒板摢|鏌ヨ鍗?.test(text)) return false;
    if (/(?:鏌ョ湅|鐪嬬湅|鍒楀嚭|鏈夊摢浜泑鍘嗗彶|鎵撳紑|鏄剧ず).*(?:璁㈠崟)/.test(text)) return true;
    if (/(?:璁㈠崟).*(?:鍒楄〃|璁板綍|鍘嗗彶)/i.test(text)) return true;
    return false;
  }

  function isOrderCreateEntryPhrase(t) {
    const text = (t || '').trim();
    if (!text) return false;
    if (isViewOrderHistoryPhrase(text)) return false;
    if (/纭涓嬪崟|寮€濮嬩笅鍗晐^涓嬪崟$|鐢熸垚璁㈠崟/.test(text)) return true;
    return false;
  }

  function isOrderViewHistoryEntryPhrase(t) {
    const text = (t || '').trim();
    if (isViewOrderHistoryPhrase(text)) return true;
    if (isOrderSkillAtEntry() && /鏌ョ湅鍘嗗彶鏁版嵁/.test(text)) return true;
    return false;
  }

  function renderOrderSkillEntryCard(c) {
    const count = ordersForCustomer(c.id).length;
    const historySub = count > 0 ? '鍏?' + count + ' 绗斿巻鍙茶鍗? : '鏆傛棤鍘嗗彶璁㈠崟';
    const historyRow =
      count > 0
        ? '<button type="button" class="sc-plan-entry__option" data-action="order-view-history">' +
          '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鏌ョ湅鍘嗗彶璁㈠崟</span>' +
          '<span class="sc-plan-entry__option-desc">' +
          App.escapeHtml(historySub) +
          '</span></span>' +
          '<span class="sc-plan-entry__chevron" aria-hidden="true">鈥?/span></button>'
        : '<div class="sc-plan-entry__option sc-plan-entry__option--disabled" aria-disabled="true">' +
          '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鏌ョ湅鍘嗗彶璁㈠崟</span>' +
          '<span class="sc-plan-entry__option-desc">' +
          App.escapeHtml(historySub) +
          '</span></span></div>';
    return (
      '<div class="sc-card sc-card--plan-entry" data-spec-id="card-order-entry">' +
      '<div class="sc-plan-entry__head">' +
      '<p class="sc-plan-entry__kicker">纭涓嬪崟</p>' +
      '<div class="sc-plan-entry__customer-row">' +
      '<span class="sc-plan-entry__customer">' +
      App.escapeHtml(c.name) +
      '</span>' +
      planEntryCustomerBadge(c) +
      '</div></div>' +
      '<div class="sc-plan-entry__actions" role="group" aria-label="纭涓嬪崟鎿嶄綔">' +
      historyRow +
      '<button type="button" class="sc-plan-entry__option sc-plan-entry__option--primary" data-action="order-create-new">' +
      '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">纭涓嬪崟</span>' +
      '<span class="sc-plan-entry__option-desc">鎸夋姤浠峰崟鎴栫洿閫夊搧锛岀‘璁ゆ槑缁嗗悗鎻愪氦</span></span>' +
      '<span class="sc-plan-entry__chevron" aria-hidden="true">鈥?/span></button>' +
      '</div></div>'
    );
  }

  /* ---------- v1.3.0 浜ゆ湡璇勫 ---------- */
  function isDeliverySkillAtEntry() {
    return !!ctx().deliverySkillAtEntry;
  }

  function setDeliverySkillAtEntry(on) {
    if (on) ctx().deliverySkillAtEntry = true;
    else if (ctx().deliverySkillAtEntry) delete ctx().deliverySkillAtEntry;
  }

  function orderStatusBadgeClass(status) {
    const meta = (DemoData.orderStatusMeta || {})[status];
    return (meta && meta.badgeClass) || 'sc-badge--new';
  }

  function orderStatusBadgeHtml(status) {
    return (
      '<span class="sc-badge ' +
      orderStatusBadgeClass(status) +
      '">' +
      App.escapeHtml(status || '鈥?) +
      '</span>'
    );
  }

  function deliveryReviewOrderNo(meta) {
    meta = meta || {};
    if (meta.orderNo) return String(meta.orderNo).replace(/^SO/i, 'XSD');
    if (meta.quoteId) return String(meta.quoteId).replace(/^QT/i, 'XSD');
    const d = new Date();
    const ymd =
      d.getFullYear() +
      String(d.getMonth() + 1).padStart(2, '0') +
      String(d.getDate()).padStart(2, '0');
    return 'XSD' + ymd + '028';
  }

  function deliveryBlockerInventoryCode(line, idx) {
    if (!line) return '000000000002AS-0001';
    const raw = line.inventoryCode || line.skuId || '';
    if (/^0+\d/.test(raw)) return raw;
    const suffix = String((idx != null ? idx : 0) + 1).padStart(4, '0');
    return '000000000002AS-' + suffix;
  }

  function buildDeliveryProcessLineReasons(count) {
    const n = Math.max(1, count || 3);
    const reasons = [];
    for (let i = 1; i <= n; i++) {
      reasons.push('绗€? + i + '銆戦亾宸ュ簭浜х嚎闆嗘病鏈夊彲鐢ㄤ骇绾?);
    }
    return reasons;
  }

  function defaultDeliveryPlanDates() {
    const start = new Date();
    start.setDate(start.getDate() + 7);
    const end = new Date(start);
    end.setDate(end.getDate() + 14);
    const fmt = function (d) {
      return d.toISOString().slice(0, 10);
    };
    return { start: fmt(start), end: fmt(end) };
  }

  function ensureDeliveryPendingLines(meta) {
    if (!meta) return [];
    if (!meta.lines || !meta.lines.length) {
      meta.lines = enrichOrderLines(deliveryLinesForReview(meta));
    } else {
      meta.lines = enrichOrderLines(meta.lines);
    }
    return meta.lines;
  }

  function renderDeliveryLineProcessVersionField(pr, line, idx) {
    const options = DemoData.processVersionOptions(pr, line.skuId);
    const cur = line.processVersion || options[0] || '鏍囧噯鐗?;
    const opts = options
      .map(function (v) {
        return (
          '<option value="' +
          App.escapeHtml(v) +
          '"' +
          (v === cur ? ' selected' : '') +
          '>' +
          App.escapeHtml(v) +
          '</option>'
        );
      })
      .join('');
    return (
      '<select class="sc-input sc-input--field sc-delivery-line__process" data-action="delivery-line-process" data-idx="' +
      idx +
      '">' +
      opts +
      '</select>'
    );
  }

  function renderDeliveryLinesProcessSection(lines) {
    if (!lines || !lines.length) return '';
    const rows = lines
      .map(function (line, idx) {
        const pr = productById(line.productId);
        if (!pr) return '';
        return (
          '<tr><td>' +
          (idx + 1) +
          '</td><td><strong>' +
          App.escapeHtml(line.inventoryName || '鈥?) +
          '</strong></td><td>' +
          renderDeliveryLineProcessVersionField(pr, line, idx) +
          '</td></tr>'
        );
      })
      .join('');
    return (
      '<label class="sc-field-label">宸ヨ壓鐗堟湰锛堟寜璐у搧锛?/label>' +
      '<div class="sc-order-confirm__table-wrap sc-delivery-lines-process">' +
      '<table class="sc-order-confirm__table sc-order-confirm__table--compact">' +
      '<thead><tr><th>#</th><th>鍝佸悕</th><th>宸ヨ壓鐗堟湰</th></tr></thead><tbody>' +
      rows +
      '</tbody></table></div>'
    );
  }

  function syncDeliveryPendingProcessFromDom(el) {
    const meta = ctx().deliveryPending;
    if (!meta || !meta.lines) return;
    meta.lines.forEach(function (line, idx) {
      const sel =
        (el && el.querySelector('[data-action="delivery-line-process"][data-idx="' + idx + '"]')) ||
        document.querySelector('[data-spec-id="sheet-delivery"] [data-action="delivery-line-process"][data-idx="' + idx + '"]');
      if (sel) {
        line.processVersion = sel.value;
        line._processVersionTouched = true;
      }
    });
  }

  function formatDeliveryLinesProcessSummary(lines) {
    if (!lines || !lines.length) return '鈥?;
    return lines
      .map(function (l, i) {
        return i + 1 + '. ' + (l.inventoryName || '鈥?) + ' ' + (l.processVersion || '鈥?);
      })
      .join('锛?);
  }

  function renderDeliverySkillEntryCard(c) {
    return (
      '<div class="sc-card sc-card--plan-entry" data-spec-id="card-delivery-entry">' +
      '<div class="sc-plan-entry__head">' +
      '<p class="sc-plan-entry__kicker">浜ゆ湡璇勫</p>' +
      '<div class="sc-plan-entry__customer-row">' +
      '<span class="sc-plan-entry__customer">' +
      App.escapeHtml(c.name) +
      '</span>' +
      planEntryCustomerBadge(c) +
      '</div></div>' +
      '<div class="sc-plan-entry__actions" role="group" aria-label="浜ゆ湡璇勫鎿嶄綔">' +
      '<button type="button" class="sc-plan-entry__option sc-plan-entry__option--primary" data-action="delivery-create-new">' +
      '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">璇勪及浜ゆ湡</span>' +
      '<span class="sc-plan-entry__option-desc">鎸夋姤浠峰崟銆佹寜璁㈠崟鎴栬嚜閫夊晢鍝?/span></span>' +
      '<span class="sc-plan-entry__chevron" aria-hidden="true">鈥?/span></button>' +
      '</div></div>'
    );
  }

  function showDeliverySkillEntry(opts) {
    opts = opts || {};
    const c = activeCustomer() || requireCustomer('delivery');
    if (!c) return;
    setDeliverySkillAtEntry(true);
    enterSkill('delivery');
    const html =
      opts.leadHtml != null && !opts.onlyCard
        ? opts.leadHtml + renderDeliverySkillEntryCard(c)
        : renderDeliverySkillEntryCard(c);
    App.pushAiHtml(html);
    rescanAnnotationPins();
  }

  function renderDeliverySourceCard(c) {
    const quotesList = c ? quotesForCustomer(c.id) : [];
    const quotesCount = quotesList.length;
    const ordersList = c ? deliveryOrdersForCustomer(c.id) : [];
    const ordersCount = ordersList.length;
    const quotesSub = quotesCount > 0 ? '鍏?' + quotesCount + ' 浠藉巻鍙叉姤浠峰崟' : '鏆傛棤鍘嗗彶鎶ヤ环鍗?;
    const ordersSub =
      ordersCount > 0 ? '鍏?' + ordersCount + ' 绗旀湭鎺掔▼璁㈠崟' : '鏆傛棤鏈帓绋嬭鍗?;
    let quoteBtnExtra = '';
    let orderBtnExtra = '';
    let meta = '';
    if (quotesCount === 1) {
      quoteBtnExtra = ' data-quote-id="' + App.escapeHtml(quotesList[0].id) + '"';
      meta +=
        '<p class="sc-card__meta">鏈鎴锋湁 <strong>1</strong> 浠芥姤浠峰崟锛岀偣銆屾寜鎶ヤ环鍗曘€嶅皢鐩存帴杩涘叆璇勫琛ㄥ崟銆?/p>';
    } else if (quotesCount > 1) {
      meta +=
        '<p class="sc-card__meta">鏈鎴峰叡鏈?<strong>' +
        quotesCount +
        '</strong> 浠芥姤浠峰崟锛屾寜鎶ヤ环鍗曡瘎浼版椂椤诲厛閫夋嫨銆?/p>';
    }
    if (ordersCount === 1) {
      orderBtnExtra = ' data-oid="' + App.escapeHtml(ordersList[0].id) + '"';
      if (!meta) {
        meta +=
          '<p class="sc-card__meta">鏈鎴锋湁 <strong>1</strong> 绗旀湭鎺掔▼璁㈠崟锛岀偣銆屾寜璁㈠崟銆嶅皢鐩存帴杩涘叆璇勫琛ㄥ崟銆?/p>';
      }
    } else if (ordersCount > 1 && !meta) {
      meta +=
        '<p class="sc-card__meta">鏈鎴峰叡鏈?<strong>' +
        ordersCount +
        '</strong> 绗旀湭鎺掔▼璁㈠崟锛屾寜璁㈠崟璇勪及鏃堕』鍏堥€夋嫨銆?/p>';
    }

    const quoteOption =
      quotesCount > 0
        ? '<button type="button" class="sc-plan-entry__option" data-action="delivery-source-quote"' +
          quoteBtnExtra +
          '>' +
          '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鎸夋姤浠峰崟</span>' +
          '<span class="sc-plan-entry__option-desc">' +
          App.escapeHtml(quotesSub) +
          '</span></span>' +
          '<span class="sc-plan-entry__chevron" aria-hidden="true">鈥?/span></button>'
        : '<div class="sc-plan-entry__option sc-plan-entry__option--disabled" aria-disabled="true">' +
          '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鎸夋姤浠峰崟</span>' +
          '<span class="sc-plan-entry__option-desc">' +
          App.escapeHtml(quotesSub) +
          '</span></span></div>';

    const orderOption =
      ordersCount > 0
        ? '<button type="button" class="sc-plan-entry__option" data-action="delivery-source-order"' +
          orderBtnExtra +
          '>' +
          '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鎸夎鍗?/span>' +
          '<span class="sc-plan-entry__option-desc">' +
          App.escapeHtml(ordersSub) +
          '</span></span>' +
          '<span class="sc-plan-entry__chevron" aria-hidden="true">鈥?/span></button>'
        : '<div class="sc-plan-entry__option sc-plan-entry__option--disabled" aria-disabled="true">' +
          '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鎸夎鍗?/span>' +
          '<span class="sc-plan-entry__option-desc">' +
          App.escapeHtml(ordersSub) +
          '</span></span></div>';

    return (
      '<div class="sc-card sc-card--compact" data-spec-id="card-delivery-source">' +
      '<div class="sc-card__head sc-card__head--compact">浜ゆ湡璇勫 路 閫夋嫨鏉ユ簮</div>' +
      '<div class="sc-plan-entry__actions" role="group" aria-label="浜ゆ湡璇勫閫夋嫨鏉ユ簮">' +
      quoteOption +
      orderOption +
      '<button type="button" class="sc-plan-entry__option sc-plan-entry__option--primary" data-action="delivery-source-lines">' +
      '<span class="sc-plan-entry__option-text"><span class="sc-plan-entry__option-title">鑷€夊晢鍝?/span>' +
      '<span class="sc-plan-entry__option-desc">鐩撮€夊搧銆佽鏍间笌鏁伴噺璇勫浜ゆ湡</span></span>' +
      '<span class="sc-plan-entry__chevron" aria-hidden="true">鈥?/span></button>' +
      '</div>' +
      meta +
      '</div>'
    );
  }

  function renderDeliveryQuotePickCard(list) {
    const rows = list
      .map(function (q) {
        return (
          '<button type="button" class="sc-follow-row sc-follow-row--select" data-action="delivery-quote-pick" data-quote-id="' +
          App.escapeHtml(q.id) +
          '"><span class="sc-follow-row__name">' +
          App.escapeHtml(q.id) +
          '</span><span class="sc-follow-row__meta">' +
          fmtMoney(q.total) +
          ' 路 ' +
          App.escapeHtml(q.templateName || '') +
          '</span></button>'
        );
      })
      .join('');
    return (
      '<div class="sc-card sc-card--compact" data-spec-id="card-delivery-quote-pick"><div class="sc-card__head sc-card__head--compact">閫夋嫨鎶ヤ环鍗?/div><div class="sc-follow-list">' +
      rows +
      '</div></div>'
    );
  }

  function renderDeliveryOrderPickCard(list) {
    const rows = list
      .map(function (o) {
        return (
          '<button type="button" class="sc-follow-row sc-follow-row--select" data-action="delivery-order-pick" data-oid="' +
          App.escapeHtml(o.id) +
          '"><span class="sc-follow-row__name">' +
          App.escapeHtml(o.no) +
          '</span><span class="sc-follow-row__meta">' +
          o.date +
          ' 路 ' +
          App.escapeHtml(o.amount) +
          '</span>' +
          orderStatusBadgeHtml(o.status) +
          '</button>'
        );
      })
      .join('');
    return (
      '<div class="sc-card sc-card--compact" data-spec-id="card-delivery-order-pick"><div class="sc-card__head sc-card__head--compact">閫夋嫨璁㈠崟</div><div class="sc-follow-list">' +
      rows +
      '</div></div>'
    );
  }

  function openDeliveryForm(meta) {
    meta = meta || {};
    ensureDeliveryPendingLines(meta);
    ctx().deliveryPending = meta;
    App.pushAiHtml(renderDeliveryFormCard());
    rescanAnnotationPins();
  }

  function deliverySummaryLabel(meta) {
    if (!meta) return '';
    if (meta.sourceType === 'quote' && meta.quoteId) {
      return '鎶ヤ环鍗?' + meta.quoteId + (meta.total != null ? ' 路 ' + fmtMoney(meta.total) : '');
    }
    if (meta.sourceType === 'order' && meta.orderNo) {
      return '璁㈠崟 ' + meta.orderNo + ' 路 ' + App.escapeHtml(meta.orderStatus || '');
    }
    if (meta.sourceType === 'lines' && meta.lines) {
      return meta.lines.length + ' 椤?路 ' + meta.lines.map(function (l) {
        return l.inventoryName;
      }).join('銆?);
    }
    return '';
  }

  function renderDeliveryFormCard() {
    const meta = ctx().deliveryPending || {};
    const lines = ensureDeliveryPendingLines(meta);
    const procOpts = (DemoData.procurementPlanOptions || [
      { value: 'yes', label: '鏄? },
      { value: 'no', label: '鍚? }
    ])
      .map(function (o) {
        return (
          '<label class="sc-radio-pill"><input type="radio" name="delivery-procurement" value="' +
          App.escapeHtml(o.value) +
          '"' +
          (o.value === 'yes' ? ' checked' : '') +
          ' /> ' +
          App.escapeHtml(o.label) +
          '</label>'
        );
      })
      .join('');
    return (
      '<div class="sc-card sc-card--compact sc-card--inline-form" data-spec-id="sheet-delivery" data-spec-pin-root>' +
      '<div class="sc-card__head sc-card__head--compact">浜ゆ湡璇勫</div>' +
      '<p class="sc-card__meta">' +
      App.escapeHtml(deliverySummaryLabel(meta)) +
      '</p>' +
      '<label class="sc-field-label">鏈熸湜浜ゆ湡</label>' +
      '<input class="sc-input sc-input--field" data-field="delivery-expected-date" type="date" value="" placeholder="璇烽€夋嫨" />' +
      renderDeliveryLinesProcessSection(lines) +
      '<label class="sc-field-label">鏄惁鐢熸垚閲囪喘璁″垝</label>' +
      '<div class="sc-radio-group sc-radio-group--inline">' +
      procOpts +
      '</div>' +
      '<div class="sc-card__actions-inline"><button type="button" class="sc-btn sc-btn--primary" data-action="delivery-submit">鎻愪氦璇勫</button></div>' +
      '</div>'
    );
  }

  function beginDeliveryFromQuote(quoteId) {
    setDeliverySkillAtEntry(false);
    const c = requireCustomer('delivery');
    if (!c) return;
    enterSkill('delivery');
    const list = quotesForCustomer(c.id);
    if (!list.length) {
      App.pushAiHtml('<p class="sc-reply-lead">褰撳墠瀹㈡埛鏆傛棤鎶ヤ环鍗曪紝璇峰厛 <strong>浜у搧鎶ヤ环</strong> 鎴栨敼鐢ㄨ嚜閫夊晢鍝佽瘎浼颁氦鏈熴€?/p>');
      App.pushAiHtml(renderDeliverySourceCard(c));
      rescanAnnotationPins();
      return;
    }
    let qid = quoteId || null;
    if (!qid && ctx().quote && ctx().quote.customerId === c.id) {
      qid = ctx().quote.id;
    }
    if (!qid && list.length > 1) {
      App.pushAiHtml(
        '<p class="sc-reply-lead">鏈鎴锋湁 <strong>' +
          list.length +
          '</strong> 浠芥姤浠峰崟锛?strong>鎸夋姤浠峰崟璇勪及椤诲厛閫夋嫨</strong>锛?/p>' +
          renderDeliveryQuotePickCard(list)
      );
      rescanAnnotationPins();
      return;
    }
    const quote = quoteForActiveCustomer(qid || list[0].id);
    if (!quote) {
      App.toast('鏈壘鍒版墍閫夋姤浠峰崟');
      return;
    }
    persistQuote(quote);
    openDeliveryForm({
      sourceType: 'quote',
      quoteId: quote.id,
      total: quote.total,
      lines: quote.lines || []
    });
  }

  function beginDeliveryFromOrder(orderId) {
    setDeliverySkillAtEntry(false);
    const c = requireCustomer('delivery');
    if (!c) return;
    enterSkill('delivery');
    const list = deliveryOrdersForCustomer(c.id);
    if (!list.length) {
      App.pushAiHtml('璇ュ鎴锋殏鏃犳湭鎺掔▼璁㈠崟锛岃鏀圭敤鎶ヤ环鍗曟垨鑷€夊晢鍝併€?);
      return;
    }
    if (orderId) {
      const hit = list.find(function (o) {
        return o.id === orderId;
      });
      if (hit) {
        deliveryOpenFormForOrder(hit);
        return;
      }
    }
    if (list.length === 1) {
      deliveryOpenFormForOrder(list[0]);
      return;
    }
    App.pushAiHtml(
      '<p class="sc-reply-lead">鏈鎴锋湁 <strong>' +
        list.length +
        '</strong> 绗旀湭鎺掔▼璁㈠崟锛?strong>鎸夎鍗曡瘎浼伴』鍏堥€夋嫨</strong>锛?/p>' +
        renderDeliveryOrderPickCard(list)
    );
    rescanAnnotationPins();
  }

  function deliveryOpenFormForOrder(o) {
    if (!o) return;
    openDeliveryForm({
      sourceType: 'order',
      orderId: o.id,
      orderNo: o.no,
      orderStatus: o.status,
      lines: (o.lines || []).length ? o.lines : null,
      productIds: o.productIds
    });
  }

  function beginDeliveryLines() {
    setDeliverySkillAtEntry(false);
    const c = requireCustomer('delivery');
    if (!c) return;
    enterSkill('delivery');
    ctx().deliveryLinesMode = true;
    ctx().quotePickForOrder = false;
    ensureOrderDraft(c);
    if (
      maybeDeliveryDemandBeforePick(c, {
        leadHtml: '<p class="sc-reply-lead">鑷€夊晢鍝佽瘎浼颁氦鏈燂細璇峰厛鎻忚堪閲囪喘闇€姹傘€?/p>'
      })
    ) {
      return;
    }
    App.pushAiHtml(
      '<p class="sc-reply-lead">鑷€夊晢鍝佽瘎浼颁氦鏈燂細璇峰湪閫夊搧鍗′腑鍕鹃€変骇鍝併€?/p>' +
        renderOrderProductPickCardForDelivery()
    );
    scheduleOrderPickLazyBind();
    rescanAnnotationPins();
  }

  function renderOrderProductPickCardForDelivery() {
    return renderOrderProductPickCard({ deliveryLines: true });
  }

  function orderToCartForDelivery(opts) {
    confirmDeliveryLines(opts);
  }

  function deliveryLinesFromOrderDraft() {
    syncOrderQtyFromDom();
    const d = ctx().orderDraft;
    if (!d) return [];
    return orderSelectedIds()
      .map(function (pid) {
        const pr = productById(pid);
        if (!pr) return null;
        return makeQuoteLine(pr, {
          skuId: d.sku[pid] || DemoData.defaultSkuId(pr),
          qty: d.qty[pid] || 1
        });
      })
      .filter(Boolean);
  }

  function confirmDeliveryLines(opts) {
    opts = opts || {};
    syncPickQueryFromDom('order');
    if (!orderSelectedIds().length) {
      App.toast('璇疯嚦灏戦€夋嫨涓€绉嶄骇鍝?);
      return;
    }
    const lines = deliveryLinesFromOrderDraft();
    if (!lines.length) {
      App.toast('璇峰厛閫夋嫨鍟嗗搧');
      return;
    }
    ctx().deliveryLinesMode = false;
    if (opts.simulateUserMsg) simulateUserUtterance('涓嬩竴姝ワ細纭閫夊搧');
    openDeliveryForm({ sourceType: 'lines', lines: lines });
  }

  function showOrderSkillEntry(opts) {
    opts = opts || {};
    const c = activeCustomer() || requireCustomer('order');
    if (!c) return;
    setOrderSkillAtEntry(true);
    enterSkill('order');
    const html =
      opts.leadHtml != null && !opts.onlyCard
        ? opts.leadHtml + renderOrderSkillEntryCard(c)
        : renderOrderSkillEntryCard(c);
    App.pushAiHtml(html);
    rescanAnnotationPins();
  }

  function openOrderHistoryFromEntry(opts) {
    opts = opts || {};
    setOrderSkillAtEntry(false);
    const c = activeCustomer() || requireCustomer('order');
    if (!c) return;
    enterSkill('order');
    const pool = ordersForCustomer(c.id);
    if (!pool.length) {
      App.pushAiHtml(renderOrderSkillEntryCard(c));
      setOrderSkillAtEntry(true);
      rescanAnnotationPins();
      return;
    }
    pushOrderHistoryView(
      c,
      pool,
      opts.leadHtml ||
        '<p class="sc-reply-lead">涓?<strong>' +
          App.escapeHtml(c.name) +
          '</strong> 鏌ョ湅鍘嗗彶璁㈠崟锛?/p>'
    );
    rescanAnnotationPins();
  }

  function tryOrderEntryIntent(t) {
    if (!isOrderSkillAtEntry()) return false;
    const text = (t || '').trim();
    if (!text) return true;
    if (isOrderViewHistoryEntryPhrase(text)) {
      openOrderHistoryFromEntry();
      return true;
    }
    if (isOrderCreateEntryPhrase(text)) {
      beginOrderCreate();
      return true;
    }
    if (/^閫夊搧|^鎸夋姤浠峰崟|^鐩存帴閫夊搧|^閫愰」|^纭涓嬪崟|^绛涢€墊^杩囨护/.test(text)) {
      guideMissingSlot('orderEntryChoice');
      return true;
    }
    guideMissingSlot('orderEntryChoice');
    return true;
  }

  function tryViewOrderHistory(t) {
    if (!isViewOrderHistoryPhrase(t)) return false;
    setOrderSkillAtEntry(false);
    const c = activeCustomer() || requireCustomer('order');
    if (!c) return true;
    enterSkill('order');
    const pool = ordersForCustomer(c.id);
    if (!pool.length) {
      App.pushAiHtml(
        '<p class="sc-reply-lead">瀹㈡埛 <strong>' +
          App.escapeHtml(c.name) +
          '</strong> 鏆傛棤鍘嗗彶璁㈠崟銆?/p>'
      );
      if (window.Annotation && Annotation.scanHosts) window.Annotation.scanHosts();
      return true;
    }
    if (pool.length === 1) {
      return viewOrderById(pool[0].id);
    }
    pushOrderHistoryView(c, pool);
    if (window.Annotation && Annotation.scanHosts) window.Annotation.scanHosts();
    return true;
  }

  function isViewQuoteHistoryPhrase(t) {
    const text = (t || '').trim();
    if (!text) return false;
    if (/涓嬪崟|鎸夋姤浠峰崟|鐢熸垚璁㈠崟|缁?+鎶ヤ环|鐩存帴閫夊搧鎶ヤ环|閫愰」鎶ヤ环|鐢熸垚鎶ヤ环鍗晐鍒涘缓鏂版姤浠穦鏂板缓鎶ヤ环|浜у搧鎶ヤ环|鎶ヤ釜浠?.test(text))
      return false;
    if (/(?:鏌ョ湅|鐪嬬湅|鍒楀嚭|鏈夊摢浜泑鍘嗗彶|鎵撳紑|棰勮|鏄剧ず).*(?:鎶ヤ环鍗晐鎶ヤ环)/.test(text)) return true;
    if (/(?:鎶ヤ环鍗?.*(?:鍒楄〃|璁板綍|鍘嗗彶|pdf|PDF)/i.test(text)) return true;
    if (/^棰勮\s*鎶ヤ环/.test(text)) return true;
    return false;
  }

  function parseSchemeViewAttributes(text) {
    let t = (text || '').trim();
    t = t
      .replace(/^(?:鏌ョ湅|鐪嬬湅|鍒楀嚭|鎵撳紑|棰勮|鏄剧ず)\s*/gi, '')
      .replace(/(?:鍘嗗彶鏂规|鏂规鍘嗗彶|鏂规鍒楄〃|鎵€鏈夋柟妗坾浠ュ墠鐨勬柟妗坾宸蹭繚瀛樼殑鏂规|鏂规璁板綍)/g, '')
      .replace(/(?:鐨??\s*鏂规\s*(?:pdf|PDF)?\s*$/gi, '')
      .trim();
    return parseSchemeQuoteAttributes(t);
  }

  function parseQuoteViewAttributes(text) {
    let t = (text || '').trim();
    t = t
      .replace(/^(?:鏌ョ湅|鐪嬬湅|鍒楀嚭|鎵撳紑|棰勮|鏄剧ず)\s*/gi, '')
      .replace(/(?:鍘嗗彶鎶ヤ环鍗晐鎶ヤ环鍗曞巻鍙瞸鎶ヤ环鍗曞垪琛▅鎵€鏈夋姤浠峰崟|浠ュ墠鐨勬姤浠峰崟|宸蹭繚瀛樼殑鎶ヤ环鍗晐鎶ヤ环璁板綍)/g, '')
      .replace(/(?:鐨??\s*鎶ヤ环鍗?\s*(?:pdf|PDF)?\s*$/gi, '')
      .trim();
    return parseOrderByQuoteAttributes(t);
  }

  /** 婕旂ず锛氬鎴峰皻鏃犲巻鍙茶褰曟椂鍐欏叆 2 鏉℃柟妗?+ 1 鏉℃姤浠峰崟锛屼究浜庛€屾煡鐪嬪巻鍙层€嶉獙鏀?*/
  function seedDemoHistoryIfEmpty(c) {
    ensureSchemesStore();
    ensureQuotesStore();
    if (schemesForCustomer(c.id).length && quotesForCustomer(c.id).length) return;

    const tpl0 = DemoData.planTemplates[0];
    const tpl1 = DemoData.planTemplates[1] || tpl0;
    const p1 = DemoData.products[0];
    const p2 = DemoData.products[1] || p1;
    const now = Date.now();
    const sku1 = DemoData.defaultSkuId(p1);
    const sku2 = DemoData.defaultSkuId(p2);

    if (!schemesForCustomer(c.id).length) {
      const seedLines1 = [
        {
          productId: p2.id,
          name: p2.name,
          skuId: sku2,
          skuLabel: DemoData.skuLabel(p2, sku2),
          qty: 2,
          sub: 0
        }
      ];
      persistScheme({
        id: 'PL' + (now - 86400000).toString().slice(-8),
        customerId: c.id,
        templateId: tpl1.id,
        templateName: buildSchemeDisplayName(c, seedLines1),
        layoutTemplateName: tpl1.name,
        lines: seedLines1,
        total: 0,
        createdAt: '2026-05-12 10:00'
      });
      const seedLines0 = [
        {
          productId: p1.id,
          name: p1.name,
          skuId: sku1,
          skuLabel: DemoData.skuLabel(p1, sku1),
          qty: 4,
          sub: 0
        }
      ];
      persistScheme({
        id: 'PL' + now.toString().slice(-8),
        customerId: c.id,
        templateId: tpl0.id,
        templateName: buildSchemeDisplayName(c, seedLines0),
        layoutTemplateName: tpl0.name,
        lines: seedLines0,
        total: 0,
        createdAt: '2026-05-18 15:30'
      });
    }

    if (!quotesForCustomer(c.id).length) {
      const sch = schemesForCustomer(c.id)[0];
      const qtTpl = DemoData.quoteTemplates[0];
      const unit = 32000;
      const lines = (sch.lines || []).map(function (l) {
        const qty = l.qty || 1;
        return {
          inventoryName: l.name,
          name: l.name,
          skuLabel: l.skuLabel,
          qty: qty,
          quotePrice: unit,
          sub: unit * qty
        };
      });
      const total = lines.reduce(function (s, l) {
        return s + (l.sub || 0);
      }, 0);
      persistQuote({
        id: 'QT' + (now - 43200000).toString().slice(-8),
        templateId: qtTpl.id,
        templateName: qtTpl.name,
        schemeId: sch ? sch.id : null,
        customerId: c.id,
        total: total,
        lines: lines,
        createdAt: '2026-05-16 11:00'
      });
    }
  }

  function schemeHistoryRowTitle(s) {
    const name = (s && s.templateName) || '鏈懡鍚嶆柟妗?;
    const c = s && s.customerId ? App.getCustomer(s.customerId) : null;
    const cname = c && c.name ? String(c.name).trim() : '';
    if (cname && name.indexOf(cname) === 0) {
      const rest = name.slice(cname.length).trim();
      return rest || name;
    }
    return name;
  }

  function renderSchemeCardHtml(scheme, c, tpl, opts) {
    opts = opts || {};
    const lineHtml = (scheme.lines || [])
      .map(
        (l) =>
          '<p class="sc-card__meta">' +
          App.escapeHtml(l.name) +
          ' 路 ' +
          App.escapeHtml(l.skuLabel) +
          ' 脳' +
          l.qty +
          '</p>'
      )
      .join('');
    const customerLine = opts.hideCustomer
      ? ''
      : '<p class="sc-card__meta">瀹㈡埛锛? + App.escapeHtml(c.name) + '</p>';
    const displayName = opts.hideCustomer
      ? schemeHistoryRowTitle(scheme)
      : scheme.templateName || '鈥?;
    return (
      '<div class="sc-card" data-spec-id="card-scheme"><div class="sc-card__head sc-card__head--compact">鏂规 ' +
      App.escapeHtml(scheme.id) +
      '</div><div class="sc-card__row sc-card__row--compact">' +
      customerLine +
      '<p class="sc-card__meta">鏂规鍚嶇О锛? +
      App.escapeHtml(displayName) +
      '</p><p class="sc-card__meta">鐗堝紡妯℃澘锛? +
      App.escapeHtml(
        (tpl && tpl.name) || scheme.layoutTemplateName || '鈥?
      ) +
      '锛堟柟妗堟鏂囦笉鍚环鏍硷級</p>' +
      lineHtml +
      '<div class="sc-card__actions-inline">' +
      '<button type="button" class="sc-btn sc-btn--ghost" data-action="open-pdf" data-pdf="鏂规">棰勮 PDF</button>' +
      '<button type="button" class="sc-btn sc-btn--ghost-primary" data-action="quote-from-scheme" data-scheme-id="' +
      App.escapeHtml(scheme.id) +
      '">鍘绘姤浠?/button>' +
      '</div></div></div>'
    );
  }

  /** 鍘嗗彶鏂规鍒楄〃鐐归€夛細浠呭嚭鏂规鍗★紱PDF 鐢卞崱涓娿€岄瑙?PDF銆嶆寜閽墦寮€ */
  function viewSchemeById(sid, opts) {
    opts = opts || {};
    const scheme = schemeForActiveCustomer(sid);
    if (!scheme) {
      App.toast('鏈壘鍒拌鏂规');
      return false;
    }
    clearActivePickList();
    const c = App.getCustomer(scheme.customerId) || activeCustomer();
    persistScheme(scheme);
    const tpl = DemoData.planTemplates.find(function (x) {
      return x.id === scheme.templateId;
    });
    const utterLabel = scheme.templateName || scheme.id;
    const userLine = opts.announceRow
      ? '绗?' + opts.announceRow + ' 鏉?
      : '鏌ョ湅鏂规 ' + utterLabel;
    pushNextAiCard(renderSchemeCardHtml(scheme, c, tpl, { hideCustomer: true }), userLine);
    if (window.Annotation && Annotation.scanHosts) window.Annotation.scanHosts();
    return true;
  }

  function renderQuoteCardHtml(quote, c, tpl) {
    let schemeNameLine = '';
    if (quote.sourceType === 'scheme' && quote.schemeId) {
      const sch = schemesForCustomer(c.id).find((s) => s.id === quote.schemeId);
      if (sch && sch.templateName) {
        schemeNameLine =
          '<p class="sc-card__meta">鏂规鍚嶇О锛? + App.escapeHtml(sch.templateName) + '</p>';
      }
    }
    return (
      '<div class="sc-card" data-spec-id="card-quote"><div class="sc-card__head sc-card__head--compact">鎶ヤ环鍗?' +
      App.escapeHtml(quote.id) +
      '</div><div class="sc-card__row sc-card__row--compact"><p class="sc-card__meta">瀹㈡埛锛? +
      App.escapeHtml(c.name) +
      '</p>' +
      schemeNameLine +
      '<p class="sc-card__meta">鎶ヤ环鍗曟ā鏉匡細' +
      App.escapeHtml((tpl && tpl.name) || quote.templateName || '鈥?) +
      '</p><p class="sc-card__meta"><strong>鎶ヤ环閲戦 ' +
      fmtMoney(quote.total) +
      '</strong></p><div class="sc-card__actions-inline"><button type="button" class="sc-btn sc-btn--ghost" data-action="open-pdf" data-pdf="鎶ヤ环">鐪?PDF</button><button type="button" class="sc-btn sc-btn--ghost-primary" data-action="order-from-quote" data-quote-id="' +
      App.escapeHtml(quote.id) +
      '">鐢熸垚璁㈠崟</button></div></div></div>'
    );
  }

  /** 鍘嗗彶鎶ヤ环鍗曞垪琛ㄧ偣閫夛細浠呭嚭鎶ヤ环鍗曞崱锛汸DF 鐢卞崱涓娿€岀湅 PDF銆嶆墦寮€ */
  function viewQuoteById(qid, opts) {
    opts = opts || {};
