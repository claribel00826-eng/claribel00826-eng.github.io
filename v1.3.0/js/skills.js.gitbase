    },
    quoteSchemePick: {
      message: '璇烽€夋嫨瑕佹姤浠风殑鏂规',
      hint: '鍦ㄤ笅鍒楁柟妗堜腑鐐归€変竴琛岋紙鏂规鍚嶇О锛夛紝鎴栬鍑烘柟妗堝悕绉?缂栧彿',
      specId: 'card-scheme-pick',
      ensureCard: function () {
        enterSkill('quote');
        const c = activeCustomer();
        if (!c) return;
        if (!document.querySelector('[data-spec-id="card-scheme-pick"]')) {
          const pool = schemesForCustomer(c.id);
          if (pool.length) pushSchemePickForQuote(c, null, pool);
        }
      }
    },
    quotePickProducts: {
      message: '璇疯嚦灏戦€夋嫨涓€绉嶄骇鍝?,
      hint: '鍦ㄩ€夊搧鎶ヤ环鍗″嬀閫変骇鍝侊紝鎴栬ˉ鍏呭搧鍚嶅悗閲嶈瘯',
      toast: '璇疯嚦灏戦€夋嫨涓€绉嶄骇鍝?,
      specId: 'card-quote-pick',
      ensureCard: function () {
        enterSkill('quote');
        const c = activeCustomer();
        if (!c) return;
        if (!document.querySelector('[data-spec-id="card-quote-pick"]')) {
          quoteDirectStart();
        }
      }
    },
    quoteLinePrice: {
      message: '璇蜂负姣忛」浜у搧濉啓鏈崟鎶ヤ环',
      hint: '鍦ㄩ€愰」鎶ヤ环鍗＄墖涓～鍐欏崟浠凤紝鎴栬銆屼己鏈嶇數鏈烘敼4200銆?,
      toast: '璇蜂负姣忛」浜у搧濉啓鏈崟鎶ヤ环',
      specId: 'sheet-quote-setup',
      ensureCard: function () {
        if (!isQuoteSetupOpen()) openQuoteSetupSheet();
      },
      focusSpecId: 'sheet-quote-setup'
    },
    quoteTemplate: {
      message: '璇烽€夋嫨鎶ヤ环鍗曟ā鏉?,
      toast: '璇烽€夋嫨鎶ヤ环鍗曟ā鏉?,
      specId: 'sheet-quote-template',
      ensureCard: function () {
        if (!isQuoteTemplateOpen()) openQuoteTemplateSheet();
      },
