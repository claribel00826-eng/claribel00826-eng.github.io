    },
    planPickProducts: {
      message: '璇峰厛鍦ㄩ€夊搧鍗″嬀閫夎嚦灏戜竴绉嶄骇鍝?,
      hint: '鍕鹃€夊悗鐐广€岄瑙堟柟妗堛€嶏紱鎴栬銆岄€夊搧 浼烘湇鐢垫満銆嶅啀銆岄瑙堟柟妗堛€?,
      toast: '璇疯嚦灏戦€夋嫨涓€绉嶄骇鍝?,
      specId: 'card-plan-pick',
      ensureCard: function () {
        enterSkill('plan');
        const c = activeCustomer();
        if (!c) return;
        if (!document.querySelector('[data-spec-id="card-plan-pick"]')) {
          ensurePlan(c);
          App.pushAiHtml(renderProductPickCard());
          schedulePlanPickLazyBind();
        }
      }
    },
    planCartEmpty: {
      message: '灏氭湭棰勮鏂规锛岃鍏堝湪閫夊搧鍗″嬀閫変骇鍝?,
      hint: '鍦ㄩ€夊搧鍗″嬀閫夊悗鐐广€岄瑙堟柟妗堛€嶏紝鎴栬銆岄瑙堟柟妗堛€?,
      toast: '璇峰厛鍕鹃€変骇鍝佸苟棰勮鏂规',
      specId: 'card-plan-pick',
      ensureCard: function () {
        guideMissingSlot('planPickProducts', { skipToast: true });
      }
    },
    planTemplate: {
      message: '璇烽€夋嫨鏂规妯℃澘',
      hint: '鍦ㄥ崱鐗囦腑鐐归€夋垨璇淬€岀1涓€嶃€佹ā鏉垮悕绉帮紱璇淬€屼繚瀛樻柟妗堛€嶇‘璁?,
      toast: '璇烽€夋嫨鏂规妯℃澘',
      specId: 'sheet-plan-template',
      ensureCard: function () {
        if (!isActiveFlowCard('sheet-plan-template')) openPlanTemplateSheet();
      },
      focusSpecId: 'sheet-plan-template'
    },
    quoteSource: {
      message: '璇烽€夋嫨鎶ヤ环鏉ユ簮锛氭寜鏂规鎶ヤ环鎴栫洿鎺ラ€夊搧',
      specId: 'card-quote-source',
      ensureCard: function () {
        enterSkill('quote');
        const c = activeCustomer();
        if (!c) return;
        if (document.querySelector('[data-spec-id="card-quote-pick"]')) return;
        if (document.querySelector('[data-spec-id="card-quote-source"]')) return;
        if (!schemesForCustomer(c.id).length) {
